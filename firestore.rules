rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isAdmin() {
      return isSignedIn()
             && exists(userDocPath(request.auth.uid))
             && get(userDocPath(request.auth.uid)).data.role == 'Admin';
    }

    function isRestaurantOwner(restaurantId) {
      return isSignedIn()
             && restaurantId is string
             && restaurantId != ''
             && exists(/databases/$(database)/documents/restaurants/$(restaurantId))
             && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    function isOrderRestaurantOwnerByOrderId(orderId) {
      return isSignedIn()
             && orderId is string
             && orderId != ''
             && exists(/databases/$(database)/documents/orders/$(orderId))
             && isRestaurantOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.restaurantId);
    }

    // Restaurants: anyone can read; only authenticated users can write
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // Food items: anyone can read; only authenticated users can write
    match /foodItems/{itemId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // Orders: authenticated users can create; owner of the order or any
    // authenticated user (restaurant owner) can read/update
    match /orders/{orderId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() || isAdmin();
      allow update, delete: if (isSignedIn() || isAdmin())
                            && (
                              resource.data.userId == request.auth.uid
                              || isRestaurantOwner(resource.data.restaurantId)
                              || isAdmin()
                            );
    }

    // Reviews: anyone can read; authenticated users can create their own
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if (isSignedIn() || isAdmin())
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isSignedIn() || isAdmin())
                             && (
                               resource.data.userId == request.auth.uid
                               || isRestaurantOwner(resource.data.restaurantId)
                               || isOrderRestaurantOwnerByOrderId(resource.data.orderId)
                               || isAdmin()
                             );
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isAdmin()
                  || (request.auth != null && request.auth.uid == userId);

      // User favorites stored as subcollection documents such as
      // /users/{userId}/favorites/restaurants and /users/{userId}/favorites/items
      match /favorites/{favoriteDoc} {
        allow read, write: if isAdmin()
                           || (request.auth != null && request.auth.uid == userId);
      }
    }

    // Favorites
    match /favorites/{userId} {
      allow read, write: if isAdmin()
                         || (request.auth != null && request.auth.uid == userId);
    }

    // Food safety reports
    match /reports/{reportId} {
      // Admin can read all. Reporter and restaurant owner can read related reports.
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid)
                  || (isSignedIn() && isRestaurantOwner(resource.data.restaurantId));

      // Authenticated users can create reports only for themselves.
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.restaurantId is string
                    && request.resource.data.restaurantId != ''
                    && request.resource.data.orderId is string
                    && request.resource.data.orderId != ''
                    && request.resource.data.reason is string
                    && request.resource.data.reason != ''
                    && request.resource.data.description is string
                    && request.resource.data.description != ''
                    && request.resource.data.status == 'pending';

      // Only admins can review/resolve/update/delete reports.
      allow update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      // Owner of the notification and admins can read.
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Allow create for authenticated users. (Needed for report submission flow.)
      allow create: if isSignedIn();

      // Owner can update basic read state, admin can update/delete everything.
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.userId == request.auth.uid
                        && request.resource.data.userId == resource.data.userId);
      allow delete: if isAdmin();
    }
  }
}
